{
  "name": "doc-review",
  "version": "1.0.0",
  "description": "Orquestra validação automática de PRD/SPEC usando architecture-review, requirements-analysis e tech-stack-validator",
  "author": "FGR Ops Team",
  "slashCommand": "doc-review",
  "invokePatterns": [
    "doc-review",
    "doc-review [file]",
    "doc-review [file] auto",
    "review documentation",
    "validate requirement changes"
  ],
  "examples": [
    "/doc-review docs/PRD/03-requisitos-funcionais.md",
    "/doc-review docs/SPEC/02-queue-engine.md auto",
    "/doc-review auto"
  ],
  "requiredSkills": [
    "architecture-review",
    "requirements-analysis",
    "tech-stack-validator"
  ],
  "permissions": [
    "read:files",
    "write:files",
    "execute:skills"
  ],
  "tags": ["documentation", "validation", "prd-spec", "automated-review"],
  "category": "documentation"
}
